# Local Postgres (docker-compose up -d). Port 5434 to avoid clashing with a system Postgres on 5432.
DATABASE_URL="postgres://corgi:corgi@localhost:5434/corgi"

# Optional: Resend API key for approval-notification emails. Left blank => emails are logged, not sent.
RESEND_API_KEY=""
FILING_NOTIFY_TO="compliance@example.com"
CRON_SECRET=""
